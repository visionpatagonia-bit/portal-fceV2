# ── NEXUS AI Proxy — Configuración ───────────────────────────────
# Copiar este archivo como .env y ajustar valores

# Puerto donde corre el proxy (este es el que expone el tunnel)
PORT=3100

# URL de Ollama (default: local)
OLLAMA_URL=http://localhost:11434

# Modelo a usar (debe estar descargado en Ollama)
OLLAMA_MODEL=llama3.2

# API Key para proteger el endpoint (los alumnos la reciben embebida en el portal)
# Generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=nexus-fce-2026-changeme

# Rate limit: máx requests por minuto por IP
RATE_LIMIT_PER_MIN=20

# Máx tokens por respuesta (controla largo y costo GPU)
MAX_TOKENS=1024

# Temperatura default (0.3 = preciso, 0.7 = creativo)
TEMPERATURE=0.4
